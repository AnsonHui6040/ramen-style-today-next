+  readonly completionMarker?: 'results'
+}
+
+type LegacyQuestionObserver = (observation: LegacyQuestionObservation) => void
+
+let legacyQuestionObserver: LegacyQuestionObserver | null = null
+
+function deepFreezeObservation<T>(value: T): T {
+  if (value && typeof value === 'object' && !Object.isFrozen(value)) {
+    Object.values(value).forEach(deepFreezeObservation)
+    Object.freeze(value)
+  }
+  return value
+}
+
+export function registerLegacyQuestionObserver(observer: LegacyQuestionObserver) {
+  if (import.meta.env.MODE !== 'test' || legacyQuestionObserver) {
+    throw new Error('Legacy question observer is extraction-test-only')
+  }
+  legacyQuestionObserver = observer
+  return () => {
+    if (legacyQuestionObserver === observer) legacyQuestionObserver = null
+  }
+}
+
+function emitLegacyQuestionObservation(observation: LegacyQuestionObservation) {
+  legacyQuestionObserver?.(deepFreezeObservation(structuredClone(observation)))
+}
