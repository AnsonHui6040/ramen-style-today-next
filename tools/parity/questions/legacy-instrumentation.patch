+
+export interface LegacyQuestionObservation {
+  readonly transition: LegacyQuestionTransition
+  readonly displayedQuestionId?: string
+  readonly visibleOptionIds?: readonly string[]
+  readonly pendingOptionIds?: readonly string[]
+  readonly legacyAnswers?: Readonly<Record<string, string | readonly string[]>>
